{
  "name": "storybook-ai",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "NODE_USE_ENV_PROXY=1 HTTP_PROXY=${HTTP_PROXY:-$http_proxy} HTTPS_PROXY=${HTTPS_PROXY:-$https_proxy} ALL_PROXY=${ALL_PROXY:-$all_proxy} next dev",
    "build": "next build",
    "start": "NODE_USE_ENV_PROXY=1 HTTP_PROXY=${HTTP_PROXY:-$http_proxy} HTTPS_PROXY=${HTTPS_PROXY:-$https_proxy} ALL_PROXY=${ALL_PROXY:-$all_proxy} next start",
    "lint": "eslint ."
  },
  "dependencies": {
    "@google/genai": "^1.29.0",
    "@prisma/adapter-better-sqlite3": "^7.4.2",
    "@prisma/client": "^7.4.2",
    "@types/fluent-ffmpeg": "^2.1.28",
    "@types/recordrtc": "^5.6.15",
    "better-sqlite3": "^12.6.2",
    "fluent-ffmpeg": "^2.1.3",
    "next": "^15.3.0",
    "prisma": "^7.4.2",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "recordrtc": "^5.6.2"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "autoprefixer": "^10.4.21",
    "eslint": "^9",
    "eslint-config-next": "15.3.0",
    "postcss": "^8.5.3",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.8.2"
  }
