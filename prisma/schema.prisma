generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model Character {
  id            String   @id @default(cuid())
  name          String   @default("")
  description   String   @default("")
  originalImage String
  cartoonImage  String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  stories       Story[]
  relationshipsA CharacterRelationship[] @relation("RelationshipA")
  relationshipsB CharacterRelationship[] @relation("RelationshipB")
}

model Story {
  id         String      @id @default(cuid())
  title      String
  content    String
  images     String      @default("[]")
  audioUrl   String      @default("")
  createdAt  DateTime    @default(now())
  characters Character[]
}

model CharacterRelationship {
  id           String    @id @default(cuid())
  pairKey      String    @unique
  characterAId String
  characterBId String
  relationship String    @default("")
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  characterA Character @relation("RelationshipA", fields: [characterAId], references: [id], onDelete: Cascade)
  characterB Character @relation("RelationshipB", fields: [characterBId], references: [id], onDelete: Cascade)
}
