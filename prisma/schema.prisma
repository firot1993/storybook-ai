generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Character {
  id            String   @id @default(cuid())
  name          String   @default("")
  originalImage String   @default("")
  cartoonImage  String
  styleImages   Json     @default("{}")
  style         String   @default("")
  age           Int?
  voiceName     String   @default("")
  pronoun       String   @default("")
  role          String   @default("")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Storybook {
  id         String   @id @default(cuid())
  name       String
  ageRange   String   @default("")
  styleId    String   @default("")
  characters Json     @default("[]")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  chapters Story[]
}

model Synopsis {
  id           String   @id @default(cuid())
  characterIds Json     @default("[]")
  theme        String   @default("")
  keywords     String   @default("")
  ageGroup     String   @default("")
  content      String
  createdAt    DateTime @default(now())

  stories Story[]
}

model Story {
  id           String   @id @default(cuid())
  storybookId  String?
  synopsisId   String?
  characterIds Json     @default("[]")
  title        String
  synopsis     String   @default("")
  content      String
  mainImage    String   @default("")
  status       String   @default("draft")
  images       Json     @default("[]")
  audioUrl     String   @default("")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @default(now()) @updatedAt

  storybook     Storybook?     @relation(fields: [storybookId], references: [id])
  synopsis_rel  Synopsis?      @relation(fields: [synopsisId], references: [id])
  scripts       Script[]
  videoProjects VideoProject[]
  scenes        Scene[]
}

model Scene {
  id        String   @id @default(cuid())
  storyId   String
  story     Story    @relation(fields: [storyId], references: [id], onDelete: Cascade)
  index     Int
  script    String   @default("")
  imageUrl  String   @default("")
  lastFrame String   @default("")
  videoUrl  String   @default("")
  status    String   @default("pending")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Script {
  id            String   @id @default(cuid())
  storyId       String
  scenesJson    Json     @default("[]")
  totalDuration Int      @default(0)
  createdAt     DateTime @default(now())

  story         Story          @relation(fields: [storyId], references: [id], onDelete: Cascade)
  videoProjects VideoProject[]
}

model VideoProject {
  id             String   @id @default(cuid())
  storyId        String
  scriptId       String
  status         String   @default("pending")
  progress       Int      @default(0)
  sceneVideoUrls Json     @default("[]")
  rawVideoUrl    String   @default("")
  subtitlesJson  Json     @default("[]")
  finalVideoUrl  String   @default("")
  errorMessage   String   @default("")
  videoSettings  Json     @default("{}")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  story  Story  @relation(fields: [storyId], references: [id], onDelete: Cascade)
  script Script @relation(fields: [scriptId], references: [id])
}
