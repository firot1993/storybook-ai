# Local runtime
# PostgreSQL is required for the app to run locally.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/storybook_ai

# Local app URL
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Local storage for generated images, audio, and video
# If unset, the app writes to /tmp/storybook
STORAGE_LOCAL_PATH=.storybook-storage

# Optional: set this only if ffmpeg is not already available on your PATH
FFMPEG_PATH=

# Google Gemini API Key
# Get from: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Optional: Override Gemini model names
GEMINI_TEXT_MODEL=gemini-3-flash-preview
GEMINI_IMAGE_MODEL=gemini-3.1-flash-image-preview
GEMINI_STT_MODEL=gemini-2.0-flash

# ElevenLabs TTS API Key
# Required only for voice preview and narration audio
# Get from: https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

# Optional: ElevenLabs TTS model (default: eleven_v3)
# Use eleven_flash_v2_5 for faster generation at slightly lower quality
ELEVENLABS_MODEL_ID=eleven_v3

# Optional: Max concurrent ElevenLabs TTS requests (default: 5)
ELEVENLABS_CONCURRENCY=5

# Optional: ElevenLabs speaking speed (range: 0.7-1.2, default: 0.9)
# Lower values sound calmer for bedtime-style narration.
ELEVENLABS_SPEED=0.9

# Optional: ElevenLabs stability (0-1 or 0-100, default: 0.5 / 50%)
ELEVENLABS_STABILITY=0.5

# Optional: ElevenLabs style exaggeration (0-1 or 0-100, default: 0.15 / 15%)
ELEVENLABS_STYLE=0.15

# Optional: TTS voice name (maps to ElevenLabs voice ID via VOICE_MAP)
# Example: Kore, Puck, Aoede, Charon, Fenrir (or use ElevenLabs voice IDs directly)
GEMINI_TTS_VOICE=Kore

# Optional: Banana image generation model config
BANANA_API_URL=https://api.banana.dev
BANANA_API_KEY=your_banana_api_key_here
BANANA_MODEL_KEY=your_banana_model_key_here

# Optional: Invite code gate (leave unset to disable auth gate)
INVITE_CODE=your_invite_code_here

# Optional: Stable encryption key for BYOK cookies.
# If left unset in Google Cloud, onboard.sh generates and stores one for you.
BYOK_ENCRYPTION_KEY=replace_with_a_long_random_string
