# Google Gemini API Key
# Get from: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Optional: Override Gemini model names
GEMINI_TEXT_MODEL=gemini-3-flash-preview
GEMINI_IMAGE_MODEL=gemini-3.1-flash-image-preview
GEMINI_TTS_MODEL=gemini-2.5-flash-preview-tts
GEMINI_STT_MODEL=gemini-2.0-flash

# Optional: Gemini TTS voice name
# Example: Kore, Puck, Aoede, Charon, Fenrir
GEMINI_TTS_VOICE=Kore

# Optional: TTS rate-limit safety controls (defaults are safe for ~10 req/min model quota)
# Minimum gap between TTS requests in ms
GEMINI_TTS_MIN_INTERVAL_MS=6500
# Max retry attempts per TTS request (for 429/503)
GEMINI_TTS_MAX_RETRIES=4
# Base retry delay in ms when server retry hint is unavailable
GEMINI_TTS_RETRY_BASE_MS=5000

# Optional: Banana image generation model config
BANANA_API_URL=https://api.banana.dev
BANANA_API_KEY=your_banana_api_key_here
BANANA_MODEL_KEY=your_banana_model_key_here
