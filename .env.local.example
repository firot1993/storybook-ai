# Google Gemini API Key
# Get from: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Optional: Gemini TTS voice name
# Example: Kore, Puck, Aoede, Charon, Fenrir
GEMINI_TTS_VOICE=Kore

# ── xAI (Grok Imagine) — video generation provider ───────────
# Get your key at: https://console.x.ai/
# When set, the video pipeline uses xAI's grok-imagine-video model to produce
# animated scene clips instead of static images.  Narration audio is still
# generated by Gemini TTS and merged with the xAI clip via FFmpeg.
# Set imageProvider: 'xai' in VideoSettings (or leave 'auto' to prefer xAI
# when the key is present, falling back to Banana → Gemini if not).
XAI_API_KEY=your_xai_api_key_here

# Optional: override default model names
# XAI_IMAGE_MODEL=grok-imagine-image
# XAI_VIDEO_MODEL=grok-imagine-video
